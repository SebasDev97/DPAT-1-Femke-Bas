@startuml DPAT-1-Femke-Bas-Domain

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam packageStyle rectangle
hide empty members

' ============================================================
' DOMAIN LAYER — Composite pattern
' ============================================================
package "Domain" {

    abstract class StateComponent {
        +Identifier : string
        +Name : string
        +Parent : CompoundState
        +{abstract} Accept(visitor : IFsmVisitor)
        +IsDescendantOf(ancestor : CompoundState) : bool
        +GetRoot() : StateComponent
    }

    class SimpleState {
        +EntryAction : Action
        +DoAction : Action
        +ExitAction : Action
        +Accept(visitor : IFsmVisitor)
    }

    class CompoundState {
        -children : List<StateComponent>
        +EntryAction : Action
        +DoAction : Action
        +ExitAction : Action
        +AddChild(child : StateComponent)
        +RemoveChild(child : StateComponent)
        +Children : IReadOnlyList<StateComponent>
        +Accept(visitor : IFsmVisitor)
    }

    class InitialState {
        +Accept(visitor : IFsmVisitor)
    }

    class FinalState {
        +Accept(visitor : IFsmVisitor)
    }

    class Transition {
        +Identifier : string
        +Source : StateComponent
        +Destination : StateComponent
        +Trigger : Trigger
        +Guard : Guard
        +Effect : Action
        +IsAutomatic : bool
        +IsSelfTransition : bool
        +Accept(visitor : IFsmVisitor)
    }

    class Trigger {
        +Identifier : string
        +Description : string
    }

    class Action {
        +OwnerIdentifier : string
        +Description : string
        +Type : ActionType
    }

    enum ActionType {
        Entry
        Do
        Exit
        Transition
    }

    class Guard {
        +Condition : string
        +IsEmpty : bool
    }

    class StateMachine {
        +Name : string
        +RootStates : IReadOnlyList<StateComponent>
        +Transitions : IReadOnlyList<Transition>
        +Triggers : IReadOnlyList<Trigger>
        +Accept(visitor : IFsmVisitor)
        +GetAllStates() : IEnumerable<StateComponent>
        +FindStateById(id : string) : StateComponent
        +GetOutgoingTransitions(s : StateComponent) : IEnumerable<Transition>
        +GetIncomingTransitions(s : StateComponent) : IEnumerable<Transition>
    }

    ' Inheritance (Composite hierarchy)
    StateComponent <|-- SimpleState
    StateComponent <|-- CompoundState
    StateComponent <|-- InitialState
    StateComponent <|-- FinalState

    ' Composite aggregation
    CompoundState "1" o-- "*" StateComponent : children

    ' Transition relations
    Transition "*" --> "1" StateComponent : source
    Transition "*" --> "1" StateComponent : destination
    Transition "*" --> "0..1" Trigger
    Transition "*" --> "0..1" Guard
    Transition "*" --> "0..1" Action : effect

    ' State actions
    SimpleState "1" --> "0..1" Action : entry/do/exit
    CompoundState "1" --> "0..1" Action : entry/do/exit

    Action ..> ActionType

    ' StateMachine aggregations
    StateMachine "1" o-- "*" StateComponent : rootStates
    StateMachine "1" o-- "*" Transition
    StateMachine "1" o-- "*" Trigger
}

note top of StateComponent
  <b>Composite Pattern</b>
  Component = StateComponent
  Leaf = SimpleState, InitialState, FinalState
  Composite = CompoundState
end note

' ============================================================
' PARSING LAYER — Builder + Factory Method
' ============================================================
package "Parsing" {

    class FsmFileParser {
        +Parse(filePath : string) : StateMachine
        -StripCommentAndTrim(line : string) : string
        -ParseLine(line : string, builder : StateMachineBuilder)
        -ParseStateLine(line : string, builder : StateMachineBuilder)
        -ParseTriggerLine(line : string, builder : StateMachineBuilder)
        -ParseActionLine(line : string, builder : StateMachineBuilder)
        -ParseTransitionLine(line : string, builder : StateMachineBuilder)
    }

    class StateMachineBuilder {
        -name : string
        -states : Dictionary<string, StateComponent>
        -triggers : Dictionary<string, Trigger>
        -transitions : List<Transition>
        +WithName(name : string) : StateMachineBuilder
        +AddState(type : StateType, id, parentId, name) : StateMachineBuilder
        +AddTrigger(id : string, description : string) : StateMachineBuilder
        +AddAction(ownerId, description, type) : StateMachineBuilder
        +AddTransition(id, sourceId, destId, triggerId, guard) : StateMachineBuilder
        +Build() : StateMachine
    }

    class StateFactory <<static>> {
        +{static} CreateState(type : StateType, id, name) : StateComponent
    }

    enum StateType {
        Initial
        Simple
        Compound
        Final
    }

    FsmFileParser ..> StateMachineBuilder : uses
    StateMachineBuilder ..> StateFactory : uses
    StateFactory ..> StateComponent : creates
    StateMachineBuilder ..> StateMachine : builds
}

note top of StateMachineBuilder
  <b>Builder Pattern</b>
  Constructs StateMachine
  step-by-step while parsing
end note

note top of StateFactory
  <b>Factory Method</b>
  Creates correct StateComponent
  subtype based on StateType
end note

' ============================================================
' VISITORS LAYER — Visitor pattern (behavioural #1)
' ============================================================
package "Visitors" {

    interface IFsmVisitor {
        +Visit(sm : StateMachine)
        +Visit(state : SimpleState)
        +Visit(state : CompoundState)
        +Visit(state : InitialState)
        +Visit(state : FinalState)
        +Visit(transition : Transition)
    }

    class TextRenderVisitor {
        -output : StringBuilder
        -indentLevel : int
        -context : StateMachine
        +GetResult() : string
        +Visit(sm : StateMachine)
        +Visit(state : SimpleState)
        +Visit(state : CompoundState)
        +Visit(state : InitialState)
        +Visit(state : FinalState)
        +Visit(transition : Transition)
    }

    IFsmVisitor <|.. TextRenderVisitor
    TextRenderVisitor ..> StateMachine : reads
    StateComponent ..> IFsmVisitor : accept(v)
    Transition ..> IFsmVisitor : accept(v)
}

note top of IFsmVisitor
  <b>Visitor Pattern</b>
  Separates rendering logic
  from the domain model
end note

' ============================================================
' VALIDATION LAYER — Strategy pattern (behavioural #2)
' ============================================================
package "Validation" {

    interface IValidationStrategy {
        +Validate(sm : StateMachine) : IEnumerable<ValidationError>
    }

    class ValidationError {
        +Message : string
        +RelatedElementId : string
    }

    class ValidationRunner {
        -strategies : List<IValidationStrategy>
        +AddStrategy(s : IValidationStrategy) : ValidationRunner
        +RunAll(sm : StateMachine) : IReadOnlyList<ValidationError>
    }

    class DeterminismValidator {
        +Validate(sm : StateMachine) : IEnumerable<ValidationError>
    }

    class InitialFinalValidator {
        +Validate(sm : StateMachine) : IEnumerable<ValidationError>
    }

    class CompoundTargetValidator {
        +Validate(sm : StateMachine) : IEnumerable<ValidationError>
    }

    IValidationStrategy <|.. DeterminismValidator
    IValidationStrategy <|.. InitialFinalValidator
    IValidationStrategy <|.. CompoundTargetValidator
    ValidationRunner "1" o-- "*" IValidationStrategy
    ValidationRunner ..> ValidationError : produces
}

note top of IValidationStrategy
  <b>Strategy Pattern</b>
  Each validator is an
  interchangeable strategy
end note

' ============================================================
' PRESENTATION LAYER
' ============================================================
package "Presentation" {

    class ConsoleUi {
        +DisplayDiagram(sm : StateMachine)
        +DisplayState(state : StateComponent, ctx : StateMachine)
        +DisplayErrors(errors : IReadOnlyList<ValidationError>)
    }

    ConsoleUi ..> TextRenderVisitor : uses
    ConsoleUi ..> StateMachine : displays
    ConsoleUi ..> ValidationError : displays
}

' ============================================================
' APPLICATION ENTRY POINT
' ============================================================
class Program {
    +{static} Main(args : string[])
}

Program ..> FsmFileParser
Program ..> ValidationRunner
Program ..> ConsoleUi

@enduml